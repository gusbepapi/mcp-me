{
  "$description": "mcp-me “clean” curriculum vitae theme, following canonical W3C DTCG design tokens. Every engine-specific file (CSS, LaTeX, Typst, Python/ReportLab) is compiled from this single source via `scripts/build-tokens.mjs`, never hand-edited in parallel",
  "color": {
    "blue": {
      "50": { "$type": "color", "$value": "#f0f7ff" },
      "100": { "$type": "color", "$value": "#e0efff" },
      "200": { "$type": "color", "$value": "#b9dcfe" },
      "300": { "$type": "color", "$value": "#7cb9e8" },
      "400": { "$type": "color", "$value": "#5aa3d9" },
      "500": { "$type": "color", "$value": "#3b82c4" },
      "600": { "$type": "color", "$value": "#2563a0" }
    },
    "yellow": {
      "50": { "$type": "color", "$value": "#fffdf0" },
      "300": { "$type": "color", "$value": "#f5d76e" },
      "500": { "$type": "color", "$value": "#d4a72c" }
    },
    "gray": {
      "50": { "$type": "color", "$value": "#fafbff" },
      "200": { "$type": "color", "$value": "#e2e8f0" },
      "500": { "$type": "color", "$value": "#64748b" },
      "600": { "$type": "color", "$value": "#475569" },
      "800": { "$type": "color", "$value": "#1e293b" },
      "900": { "$type": "color", "$value": "#0f172a" }
    },
    "semantic": {
      "background": { "$type": "color", "$value": "{color.gray.50}" },
      "background-alt": { "$type": "color", "$value": "{color.blue.50}" },
      "text-primary": { "$type": "color", "$value": "{color.gray.800}" },
      "text-secondary": { "$type": "color", "$value": "{color.gray.600}" },
      "text-muted": { "$type": "color", "$value": "{color.gray.500}" },
      "accent": { "$type": "color", "$value": "{color.blue.300}" },
      "accent-warm": { "$type": "color", "$value": "{color.yellow.300}" },
      "border": { "$type": "color", "$value": "{color.gray.200}" }
    },
    "ats-score": {
      "excellent": { "$type": "color", "$value": "{color.blue.500}" },
      "good": { "$type": "color", "$value": "{color.blue.300}" },
      "fair": { "$type": "color", "$value": "{color.yellow.500}" },
      "poor": { "$type": "color", "$value": "#c4634a" }
    }
  },
  "dimension": {
    "radius": {
      "sm": { "$type": "dimension", "$value": "6px" },
      "md": { "$type": "dimension", "$value": "12px" },
      "lg": { "$type": "dimension", "$value": "20px" }
    }
  },
  "fontFamily": {
    "sans": {
      "$type": "fontFamily",
      "$value": ["Google Sans", "-apple-system", "Segoe UI", "Roboto", "Helvetica Neue", "Arial", "sans-serif"]
    },
    "mono": {
      "$type": "fontFamily",
      "$value": ["SF Mono", "Cascadia Code", "Fira Code", "Consolas", "monospace"]
    }
  }
}
