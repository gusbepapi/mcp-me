{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.paladini/mcp-me",
  "title": "mcp-me",
  "description": "Expose your personal, professional, educational, and social profile to any AI assistant via MCP.",
  "version": "0.6.0",
  "repository": {
    "url": "https://github.com/paladini/mcp-me",
    "source": "github"
  },
  "packages": [
    {
      "registryType": "npm",
      "identifier": "mcp-me",
      "version": "0.6.0",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "serve"
        },
        {
          "type": "positional",
          "valueHint": "profileDir",
          "description": "Profile directory (defaults to ~/.mcp-me)",
          "isRequired": false
        }
      ],
      "environmentVariables": [
        {
          "name": "MCP_ME_PROFILE_DIR",
          "description": "Path to your profile directory (overrides default ~/.mcp-me)",
          "isRequired": false,
          "isSecret": false,
          "format": "string"
        }
      ]
    }
  ]
}
